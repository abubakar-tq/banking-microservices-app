# Template for the .env file (this ONE is committed as documentation).
# Copy to .env and fill real values:  cp .env.example .env

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me
MYSQL_USER=root
MYSQL_PWD=change-me

# --- JWT (must match across gateway + auth + customer + account) ---
JWT_SECRET=change-me

# --- Service discovery (Eureka) ---
DISCOVERY_SERVICE=http://discovery-service:8761/eureka/

# --- Mail ---
MAIL_USERNAME=bank
MAIL_PASSWORD=bank
EMAIL_SYSTEM=notification@bank.com
